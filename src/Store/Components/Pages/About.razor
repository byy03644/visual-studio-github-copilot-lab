@page "/about"
@rendermode InteractiveServer

<PageTitle>About</PageTitle>

<h1>About TinyShop</h1>

<p>Loading page content...</p>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;
    [Parameter]
    [SupplyParameterFromQuery(Name = "param")]
    public string? Param { get; set; }

    protected override void OnParametersSet()
    {
        // If the required query parameter is missing, navigate to a URL that includes a default value.
        // This avoids throwing an exception during render and provides a graceful fallback.
        if (string.IsNullOrEmpty(Param))
        {
            NavigationManager.NavigateTo("/about?param=default");
        }
    }
}